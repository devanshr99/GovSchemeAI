# GovSchemeAI Backend - Environment Variables Example
# Duplicate this file to .env and configure. DO NOT commit actual secrets.

# App Config
DEBUG=False
PORT=8000
HOST=0.0.0.0

# Database
# For development: sqlite+aiosqlite:///./govscheme_ai.db
# For production (Render PostgreSQL): postgresql+asyncpg://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=sqlite+aiosqlite:///./govscheme_ai.db

# Redis URL (optional)
REDIS_URL=

# AI Provider Credentials
PRIMARY_AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model Preferences
OPENROUTER_MODEL=google/gemini-2.5-flash
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-3-haiku-20240307
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Scheduler & Scraper configurations
UPDATE_ENABLED=False
UPDATE_SCHEDULE_CRON=0 2 * * *
ADMIN_EMAIL=admin@govscheme.gov.in
SMTP_HOST=localhost
SMTP_PORT=1025
SLACK_WEBHOOK_URL=

# Security & Sessions
JWT_SECRET=some-secure-random-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Disaster Recovery & Replica Configuration (Optional)
REPLICA_DATABASE_URL=
BACKUP_STORAGE_PROVIDER=local
BACKUP_ENCRYPTION_KEY=some-other-secure-encryption-key-for-backups
